generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth Models ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Custom Flow-SMC properties
  baseCurrency  String    @default("USD")
  accountSize   Float     @default(100000)
  
  accounts      Account[]
  sessions      Session[]
  trades        TradeLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Enums for TradeLog ---
enum SessionType {
  ASIA
  LONDON
  NY
}

enum Direction {
  BUY
  SELL
}

enum Outcome {
  WIN
  LOSS
  PARTIAL_WIN
  BE
  PENDING
}

enum SweepType {
  EXTERNAL_MAJOR
  EXTERNAL_MINOR
  INTERNAL
  ASIA_HL
}

enum EntryZone {
  ORDER_BLOCK
  FVG
  BREAKER
  FLIP
}

enum ValueZone {
  PREMIUM
  DISCOUNT
  EQUILIBRIUM
}

enum Emotion {
  CALM
  FOMO
  BORED
  PANIC
  PATIENT
}

enum ExitReason {
  HIT_TP
  HIT_SL
  MANUAL_PANIC
  PARTIAL_TP
  RUNNING
}

// --- TradeLog Model ---
model TradeLog {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  
  // Relation to User
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Metadata
  title         String?
  pair          String    @default("XAUUSD")
  timeframe     String?
  session       SessionType
  direction     Direction
  riskPercent   Float
  
  // Execution Numbers
  entryPrice    Float
  stopLoss      Float
  takeProfit    Float
  realizedRR    Float?
  outcome       Outcome
  
  // SMC Strategy Constraints
  sweepType     SweepType
  hasChoch      Boolean
  entryZone     EntryZone
  valueZone     ValueZone
  
  // Imagery
  contextImgUrl String?
  entryImgUrl   String?
  
  // Psychological Factors
  preEmotion    Emotion
  duringEmotion Emotion
  exitReason    ExitReason
  journalNote   String?
}
